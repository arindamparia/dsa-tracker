# Copy this to .env for local dev with `netlify dev`
# Set all variables in Netlify dashboard: Site Settings > Environment Variables

# Neon PostgreSQL connection string
NEON_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST/YOUR_DB?sslmode=require&channel_binding=require

# Clerk Auth
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----...

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Access control
# Set to "true" to allow ALL logged-in users to access the app.
# Leave unset or "false" to restrict access to the owner only.
ALLOW_ALL_USERS=false
